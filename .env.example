# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Lakehouse paths (defaults work locally) ───────────────────────────────────
LAKEHOUSE_BASE_PATH=./data
RAW_DATA_PATH=./data/raw
BRONZE_PATH=./data/bronze
SILVER_PATH=./data/silver
GOLD_PATH=./data/gold
GOVERNANCE_PATH=./governance

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_APP_NAME=TelecomCDRLakehouse
SPARK_MASTER=local[*]
SPARK_LOG_LEVEL=WARN

# ── Model ─────────────────────────────────────────────────────────────────────
ANOMALY_THRESHOLD_PERCENTILE=95
MODEL_SAVE_PATH=./src/models/trained

# ── CDR synthetic data (mirrors Telecom Italia Milan CDR schema) ──────────────
# NUM_SQUARES: how many of the 10 000 Milan grid squares to simulate
NUM_SQUARES=500
# NUM_DAYS: days of 10-min CDR intervals to generate (starting 2013-11-01)
NUM_DAYS=7
ANOMALY_INJECTION_RATE=0.05
RANDOM_SEED=42
